generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ARTISAN
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  role          Role
  createdAt     DateTime       @default(now())
  artisanProfile ArtisanProfile?
  customerBookings Booking[]   @relation("CustomerBookings")
  reviews       Review[]       @relation("CustomerReviews")
}

model Category {
  id        String          @id
  name      String
  icon      String
  artisans  ArtisanProfile[]
}

model ArtisanProfile {
  id            String      @id @default(cuid())
  userId         String      @unique
  categoryId     String
  location       String
  priceMin       Int
  priceMax       Int
  experience     Int
  image          String
  description    String
  verified       Boolean     @default(false)
  services       Json
  availability   Json
  rating         Float       @default(0)
  reviewsCount   Int         @default(0)
  user           User        @relation(fields: [userId], references: [id])
  category       Category    @relation(fields: [categoryId], references: [id])
  reviews        Review[]
  bookings       Booking[]   @relation("ArtisanBookings")
}

model Review {
  id          String         @id @default(cuid())
  customerId  String
  artisanId   String
  rating      Int
  comment     String
  date        DateTime       @default(now())
  customer    User           @relation("CustomerReviews", fields: [customerId], references: [id])
  artisan     ArtisanProfile @relation(fields: [artisanId], references: [id])
}

model Booking {
  id          String         @id @default(cuid())
  customerId  String
  artisanId   String
  service     String
  date        String
  time        String
  location    String
  notes       String?
  status      BookingStatus  @default(PENDING)
  price       Int
  createdAt   DateTime       @default(now())
  customer    User           @relation("CustomerBookings", fields: [customerId], references: [id])
  artisan     ArtisanProfile @relation("ArtisanBookings", fields: [artisanId], references: [id])
  payment     Payment?
}

model Payment {
  id          String    @id @default(cuid())
  bookingId   String    @unique
  amount      Int
  status      String
  method      String
  createdAt   DateTime  @default(now())
  booking     Booking   @relation(fields: [bookingId], references: [id])
}
